# Copy to .env.local and fill in.
# Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Never put the service_role key in this file or in .env.local.
# It bypasses Row Level Security, and any NEXT_PUBLIC_ variable is
# shipped to the browser. Server-side secrets belong in the hosting
# platform's environment settings, without the NEXT_PUBLIC_ prefix.
