# Copy to .env.local and fill in.
# Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL of the deployment. Feeds Next's metadataBase, so Open Graph
# and canonical URLs resolve correctly. Defaults to http://localhost:3000 for
# local dev; set to the real origin (e.g. https://cubehub.vercel.app) in prod.
NEXT_PUBLIC_SITE_URL=

# Never put the service_role key in this file or in .env.local.
# It bypasses Row Level Security, and any NEXT_PUBLIC_ variable is
# shipped to the browser. Server-side secrets belong in the hosting
# platform's environment settings, without the NEXT_PUBLIC_ prefix.
